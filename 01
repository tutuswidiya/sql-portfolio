SELECT
    YEAR(OrderDate) AS Year,
    MONTH(OrderDate) AS Month,
    SUM(P.Price * O.Quantity) AS TotalSales
FROM Orders O
JOIN Products P
ON O.ProductID = P.ProductID
GROUP BY YEAR(OrderDate), MONTH(OrderDate);
